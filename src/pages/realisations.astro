---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE, UI } from '../consts';
import page from '../data/realisations.json';

// Projets éditables au CMS (collection « realisations »), regroupés par
// catégorie dans l'ordre défini par page.categoryOrder.
const projects = await getCollection('realisations', ({ data }) => !data.draft);
const rank = (c: string) => {
  const i = page.categoryOrder.indexOf(c);
  return i === -1 ? 999 : i;
};
const categories = [...new Set(projects.map((p) => p.data.category))].sort(
  (a, b) => rank(a) - rank(b) || a.localeCompare(b, 'fr')
);
const galleries = categories.map((name) => ({
  name,
  items: projects
    .filter((p) => p.data.category === name)
    .sort((a, b) => a.data.order - b.data.order),
}));

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: SITE.url },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Réalisations',
      item: new URL('/realisations', SITE.url).href,
    },
  ],
};
---

<BaseLayout
  title={page.seo.title}
  description={page.seo.description}
  jsonLd={[breadcrumb]}
>
  <section class="section">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">{page.eyebrow}</p>
        <h1>{page.title}</h1>
        <p class="lead">{page.lead}</p>
      </div>

      {
        galleries.map((g) => (
          <div class="gallery-block reveal">
            <h2>{g.name}</h2>
            <div class="grid-auto">
              {g.items.map((it) => (
                <figure class="gal">
                  {it.data.cover ? (
                    <img
                      src={it.data.cover}
                      alt={it.data.coverAlt || it.data.title}
                      width="480"
                      height="640"
                      loading="lazy"
                      decoding="async"
                    />
                  ) : (
                    <div class="placeholder" data-variant={it.data.variant}>
                      <span class="placeholder-label">Photo — {it.data.title}</span>
                    </div>
                  )}
                </figure>
              ))}
            </div>
          </div>
        ))
      }

      {page.note && <p class="gallery-note">{page.note}</p>}
    </div>
  </section>

  <section class="section-tight">
    <div class="container">
      <div class="cta-band">
        <div>
          <p class="eyebrow">{page.ctaBand.eyebrow}</p>
          <h2>{page.ctaBand.title}</h2>
        </div>
        <a class="btn btn-primary" href="/contact">{page.ctaBand.buttonLabel || UI.ctaLabel}</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .gallery-block {
    margin-bottom: clamp(40px, 6vw, 72px);
  }
  .gallery-block h2 {
    margin-bottom: 20px;
  }
  .gal {
    aspect-ratio: 3 / 4;
    margin: 0;
    overflow: hidden;
  }
  .gal img,
  .gal .placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: flex;
  }
  .gallery-note {
    font-size: 0.85rem;
    color: var(--muted);
    font-style: italic;
  }
  .cta-band {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding: clamp(28px, 4vw, 48px);
    background: var(--accent-tint);
    border-radius: var(--radius);
  }
  .cta-band h2 {
    margin: 0;
  }
</style>
