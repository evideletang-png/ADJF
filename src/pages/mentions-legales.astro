---
import { getEntry, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const entry = await getEntry('legal', 'mentions-legales');
if (!entry) throw new Error('Contenu légal manquant : mentions-legales');
const { Content } = await render(entry);
---

<BaseLayout
  title={entry.data.title}
  description="Mentions légales de L'atelier des jours fleuris."
  noindex={true}
>
  <section class="section">
    <div class="container narrow">
      <p class="eyebrow">Cadre légal</p>
      <h1>{entry.data.title}</h1>
      <div class="prose">
        <Content />
      </div>
    </div>
  </section>
</BaseLayout>
