---
import BaseLayout from '../layouts/BaseLayout.astro';
import Reviews from '../components/Reviews.astro';
import { SITE } from '../consts';

const steps = [
  {
    title: 'L’écoute',
    copy: 'Tout commence par une conversation : votre lieu, votre saison, vos couleurs et l’émotion recherchée.',
  },
  {
    title: 'La proposition',
    copy: 'Une sélection florale claire, de saison, priorisée selon ce qui compte le plus pour vous.',
  },
  {
    title: 'La création',
    copy: 'Composition, installation et petites attentions, pour un résultat fidèle à l’intention de départ.',
  },
];

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: SITE.url },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'À propos',
      item: new URL('/a-propos', SITE.url).href,
    },
  ],
};
---

<BaseLayout
  title="À propos"
  description="L'atelier des jours fleuris, c'est Léana : une fleuriste événementielle attachée aux fleurs de saison, au sur-mesure et au soin du détail."
  jsonLd={[breadcrumb]}
>
  <section class="section about-hero">
    <div class="container about-grid">
      <div>
        <p class="eyebrow">L’atelier</p>
        <h1>Des fleurs sensibles, au rythme des saisons</h1>
        <p class="lead">
          L’atelier des jours fleuris, c’est Léana : une fleuriste événementielle
          qui compose des créations sur mesure pour les mariages, les événements et
          les lieux qui reçoivent.
        </p>
        <p>
          Ici, on ne travaille pas à partir d’un catalogue figé, mais avec ce que la
          saison offre de plus beau. Chaque projet est pensé comme une histoire :
          celle d’un lieu, d’une lumière, d’un moment à fleurir avec justesse.
        </p>
        <div class="about-actions">
          <a class="btn btn-primary" href="/contact">Travailler ensemble</a>
          <a class="btn-link" href="/prestations">Voir les prestations</a>
        </div>
      </div>
      <div class="about-portrait placeholder" data-variant="iris">
        <span class="placeholder-label">Portrait — Léana</span>
      </div>
    </div>
  </section>

  <section class="section demarche">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">La démarche</p>
        <h2>Comment nous travaillons</h2>
      </div>
      <div class="grid-auto">
        {
          steps.map((s) => (
            <div class="step reveal">
              <h3>{s.title}</h3>
              <p>{s.copy}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section reviews-section">
    <div class="container">
      <Reviews />
    </div>
  </section>

  <section class="section-tight">
    <div class="container">
      <div class="cta-band">
        <div>
          <p class="eyebrow">Votre projet</p>
          <h2>Racontez-nous votre événement</h2>
        </div>
        <a class="btn btn-primary" href="/contact">Demander un devis</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .about-grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: clamp(28px, 5vw, 64px);
    align-items: center;
  }
  .about-actions {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-top: 24px;
  }
  .about-portrait {
    aspect-ratio: 4 / 5;
    display: flex;
  }
  .step {
    padding: 26px;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius);
  }
  .step h3 {
    margin-bottom: 8px;
  }
  .step p {
    margin: 0;
    color: var(--muted);
  }
  .reviews-section {
    background: var(--surface);
    border-block: 1px solid var(--line-soft);
  }
  .cta-band {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding: clamp(28px, 4vw, 48px);
    background: var(--accent-tint);
    border-radius: var(--radius);
  }
  .cta-band h2 {
    margin: 0;
  }

  @media (max-width: 860px) {
    .about-grid {
      grid-template-columns: 1fr;
    }
    .about-portrait {
      order: -1;
      max-width: 420px;
    }
  }
</style>
