---
import BaseLayout from '../layouts/BaseLayout.astro';
import Reviews from '../components/Reviews.astro';
import { SITE, UI } from '../consts';
import about from '../data/about.json';

const steps = about.steps;

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: SITE.url },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'À propos',
      item: new URL('/a-propos', SITE.url).href,
    },
  ],
};
---

<BaseLayout
  title={about.seo.title}
  description={about.seo.description}
  jsonLd={[breadcrumb]}
>
  <section class="section about-hero">
    <div class="container about-grid">
      <div>
        <p class="eyebrow">{about.eyebrow}</p>
        <h1>{about.title}</h1>
        <p class="lead">{about.lede}</p>
        <p>{about.body}</p>
        <div class="about-actions">
          <a class="btn btn-primary" href="/contact">{about.primaryCtaLabel}</a>
          <a class="btn-link" href="/prestations">{about.secondaryCtaLabel}</a>
        </div>
      </div>
      {
        about.portrait.image ? (
          <img
            class="about-portrait"
            src={about.portrait.image}
            alt={about.portrait.alt}
            width="420"
            height="525"
            loading="lazy"
            decoding="async"
          />
        ) : (
          <div class="about-portrait placeholder" data-variant="iris">
            <span class="placeholder-label">
              {about.portrait.alt ? `Photo — ${about.portrait.alt}` : 'Portrait — Léana'}
            </span>
          </div>
        )
      }
    </div>
  </section>

  <section class="section demarche">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">{about.demarcheEyebrow}</p>
        <h2>{about.demarcheTitle}</h2>
      </div>
      <div class="grid-auto">
        {
          steps.map((s) => (
            <div class="step reveal">
              <h3>{s.title}</h3>
              <p>{s.copy}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section reviews-section">
    <div class="container">
      <Reviews />
    </div>
  </section>

  <section class="section-tight">
    <div class="container">
      <div class="cta-band">
        <div>
          <p class="eyebrow">{about.ctaBand.eyebrow}</p>
          <h2>{about.ctaBand.title}</h2>
        </div>
        <a class="btn btn-primary" href="/contact">{UI.ctaLabel}</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .about-grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: clamp(28px, 5vw, 64px);
    align-items: center;
  }
  .about-actions {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-top: 24px;
  }
  .about-portrait {
    aspect-ratio: 4 / 5;
    display: flex;
    width: 100%;
  }
  img.about-portrait {
    object-fit: cover;
    border-radius: var(--radius);
  }
  .step {
    padding: 26px;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius);
  }
  .step h3 {
    margin-bottom: 8px;
  }
  .step p {
    margin: 0;
    color: var(--muted);
  }
  .reviews-section {
    background: var(--surface);
    border-block: 1px solid var(--line-soft);
  }
  .cta-band {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding: clamp(28px, 4vw, 48px);
    background: var(--accent-tint);
    border-radius: var(--radius);
  }
  .cta-band h2 {
    margin: 0;
  }

  @media (max-width: 860px) {
    .about-grid {
      grid-template-columns: 1fr;
    }
    .about-portrait {
      order: -1;
      max-width: 420px;
    }
  }
</style>
