---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import { SITE } from '../../consts';
import pages from '../../data/pages.json';

const P = pages.prestationsIndex;

const prestations = (
  await getCollection('prestations', ({ data }) => !data.draft)
).sort((a, b) => a.data.order - b.data.order);

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: SITE.url },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Prestations',
      item: new URL('/prestations', SITE.url).href,
    },
  ],
};
---

<BaseLayout
  title={P.seo.title}
  description={P.seo.description}
  jsonLd={[breadcrumb]}
>
  <section class="section">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">{P.eyebrow}</p>
        <h1>{P.title}</h1>
        <p class="lead">{P.lead}</p>
      </div>
      <div class="grid-auto">
        {
          prestations.map((p) => (
            <ServiceCard
              title={p.data.title}
              excerpt={p.data.description}
              href={`/prestations/${p.id}`}
              tags={p.data.tags.slice(0, 3)}
              variant={p.data.variant}
              image={p.data.image}
              imageAlt={p.data.imageAlt}
            />
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
