---
import BaseLayout from '../layouts/BaseLayout.astro';
import Sprig from '../components/Sprig.astro';
import { UI } from '../consts';

const NF = UI.notFound;
---

<BaseLayout title="Page introuvable" description="Cette page n'existe pas ou plus." noindex={true}>
  <section class="section notfound">
    <div class="container narrow text-center">
      <Sprig size={78} animate />
      <p class="eyebrow centered">{NF.eyebrow}</p>
      <h1>{NF.title}</h1>
      <p class="lead">{NF.lead}</p>
      <div class="notfound-actions">
        <a class="btn btn-primary" href="/">{NF.homeLabel}</a>
        <a class="btn btn-ghost" href="/prestations">{NF.prestationsLabel}</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .notfound {
    padding-block: clamp(60px, 12vw, 140px);
  }
  .notfound :global(.sprig) {
    margin: 0 auto 10px;
  }
  .notfound .lead {
    margin-inline: auto;
  }
  .notfound-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: center;
    margin-top: 26px;
  }
</style>
