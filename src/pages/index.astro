---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ServiceCard from '../components/ServiceCard.astro';
import ArticleCard from '../components/ArticleCard.astro';
import Reviews from '../components/Reviews.astro';
import Carousel from '../components/Carousel.astro';
import { SITE, UI } from '../consts';
import home from '../data/home.json';
import realisationsPage from '../data/realisations.json';

const prestations = (
  await getCollection('prestations', ({ data }) => !data.draft)
).sort((a, b) => a.data.order - b.data.order);

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);

// Réalisations récentes — depuis la collection (photos éditables au CMS).
const catRank = (c: string) => {
  const i = realisationsPage.categoryOrder.indexOf(c);
  return i === -1 ? 999 : i;
};
const realisations = (
  await getCollection('realisations', ({ data }) => !data.draft)
)
  .sort(
    (a, b) =>
      catRank(a.data.category) - catRank(b.data.category) ||
      a.data.order - b.data.order
  )
  .slice(0, 6);

const intro = home.intro;
---

<BaseLayout
  title={home.seo.title}
  description={home.seo.description || SITE.description}
>
  <Hero slides={home.heroSlides} band={home.heroBand} />

  <!-- Positionnement -->
  <section class="section-tight intro">
    <div class="container">
      <div class="intro-grid">
        {
          intro.map((item) => (
            <div class="intro-item reveal">
              <h2>{item.title}</h2>
              <p>{item.copy}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Prestations -->
  <section class="section" id="prestations">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">{home.prestationsSection.eyebrow}</p>
        <h2>{home.prestationsSection.title}</h2>
        <p class="lead">{home.prestationsSection.copy}</p>
      </div>
      <div class="grid-auto">
        {
          prestations.map((p) => (
            <ServiceCard
              title={p.data.title}
              excerpt={p.data.description}
              href={`/prestations/${p.id}`}
              tags={p.data.tags.slice(0, 3)}
              variant={p.data.variant}
              image={p.data.image}
              imageAlt={p.data.imageAlt}
            />
          ))
        }
      </div>
    </div>
  </section>

  <!-- Citation -->
  <section class="quote-band">
    <div class="container">
      <p class="reveal">« {home.quote} »</p>
    </div>
  </section>

  <!-- Réalisations -->
  <section class="section" id="realisations">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">{home.realisationsSection.eyebrow}</p>
        <h2>{home.realisationsSection.title}</h2>
      </div>
      <Carousel label="Réalisations récentes" itemWidth="min(84%, 340px)">
        {
          realisations.map((r) => (
            <a class="realisation" href="/realisations">
              <div class="realisation-media">
                {r.data.cover ? (
                  <img
                    src={r.data.cover}
                    alt={r.data.coverAlt || r.data.title}
                    width="340"
                    height="453"
                    loading="lazy"
                    decoding="async"
                  />
                ) : (
                  <div class="placeholder" data-variant={r.data.variant}>
                    <span class="placeholder-label">Photo — {r.data.title}</span>
                  </div>
                )}
              </div>
              <div class="realisation-cap">
                <span class="tag">{r.data.category}</span>
                <span>{r.data.title}</span>
              </div>
            </a>
          ))
        }
      </Carousel>
      <p class="section-cta"><a class="btn-link" href="/realisations">{home.realisationsSection.linkLabel}</a></p>
    </div>
  </section>

  <!-- Avis -->
  <section class="section reviews-section">
    <div class="container">
      <Reviews />
    </div>
  </section>

  <!-- Journal -->
  <section class="section" id="journal">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">{home.journalSection.eyebrow}</p>
        <h2>{home.journalSection.title}</h2>
      </div>
      <div class="grid-auto">
        {
          posts.map((post) => (
            <ArticleCard
              title={post.data.title}
              excerpt={post.data.description}
              href={`/journal/${post.id}`}
              category={post.data.category}
              date={post.data.pubDate}
              readingTime={post.data.readingTime}
              variant={post.data.variant}
              image={post.data.image}
              imageAlt={post.data.imageAlt}
            />
          ))
        }
      </div>
      <p class="section-cta"><a class="btn-link" href="/journal">{home.journalSection.linkLabel}</a></p>
    </div>
  </section>

  <!-- Appel à l'action -->
  <section class="section-tight">
    <div class="container">
      <div class="cta-band reveal">
        <div>
          <p class="eyebrow">{home.cta.eyebrow}</p>
          <h2>{home.cta.title}</h2>
          <p>{home.cta.copy}</p>
        </div>
        <a class="btn btn-primary" href="/contact">{UI.ctaLabel}</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .intro-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--line);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    overflow: hidden;
  }
  .intro-item {
    background: var(--bg);
    padding: clamp(24px, 3vw, 38px);
  }
  .intro-item h2 {
    font-size: 1.4rem;
    margin-bottom: 8px;
  }
  .intro-item p {
    color: var(--muted);
    margin: 0;
  }

  .quote-band {
    background: var(--accent-tint);
    color: var(--ink);
    padding-block: clamp(56px, 9vw, 104px);
  }
  .quote-band p {
    font-family: var(--serif);
    font-size: clamp(1.6rem, 1rem + 2.8vw, 3rem);
    line-height: 1.18;
    max-width: 20ch;
    margin: 0;
  }

  .realisation {
    display: block;
    color: var(--ink);
  }
  .realisation-media {
    aspect-ratio: 3 / 4;
    overflow: hidden;
    transition: transform 0.3s ease;
  }
  .realisation:hover .realisation-media {
    transform: translateY(-4px);
  }
  .realisation-media img,
  .realisation-media .placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: flex;
  }
  .realisation-cap {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-top: 12px;
    font-size: 0.95rem;
  }

  .section-cta {
    margin-top: 26px;
  }

  .reviews-section {
    background: var(--surface);
    border-block: 1px solid var(--line-soft);
  }

  .cta-band {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding: clamp(28px, 4vw, 48px);
    background: var(--accent-tint);
    border-radius: var(--radius);
  }
  .cta-band h2 {
    margin: 0 0 8px;
  }
  .cta-band p {
    margin: 0;
    color: var(--muted);
    max-width: 48ch;
  }

  @media (max-width: 720px) {
    .intro-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
