---
import Carousel from './Carousel.astro';
import { SITE } from '../consts';
import { getReviews } from '../lib/googleReviews';

const data = await getReviews();
const reviews = data.reviews;
const count = data.count;
const average = data.average.toFixed(1);
const averageStars = Math.round(data.average);
const connected = data.source === 'google';

// Données structurées : note agrégée (étoiles dans Google) — uniquement
// quand on affiche de vrais avis Google.
const aggregateLd = connected
  ? {
      '@context': 'https://schema.org',
      '@type': 'Florist',
      '@id': SITE.url + '#business',
      name: SITE.name,
      url: SITE.url,
      aggregateRating: {
        '@type': 'AggregateRating',
        ratingValue: Number(average),
        reviewCount: count,
      },
    }
  : null;
---

<div class="reviews">
  <div class="reviews-head">
    <div>
      <p class="eyebrow">Avis clients</p>
      <h2>Ce qu'elles et ils en disent</h2>
    </div>
    <div class="reviews-score">
      <span class="score-num">{average}</span>
      <span class="stars" aria-hidden="true">
        {Array.from({ length: 5 }).map((_, i) => (
          <span class={i < averageStars ? 'on' : ''}>★</span>
        ))}
      </span>
      <span class="score-meta">
        {count} avis&nbsp;·&nbsp;
        {SITE.googleBusinessUrl ? (
          <a href={SITE.googleBusinessUrl} target="_blank" rel="noreferrer">Google</a>
        ) : (
          'Google'
        )}
      </span>
    </div>
  </div>

  <Carousel label="Avis clients" itemWidth="min(90%, 360px)">
    {
      reviews.map((r) => (
        <blockquote class="review-card">
          <span class="stars" aria-label={`Note : ${r.rating} sur 5`}>
            {Array.from({ length: 5 }).map((_, i) => (
              <span class={i < r.rating ? 'on' : ''} aria-hidden="true">★</span>
            ))}
          </span>
          <p class="review-text">{r.text}</p>
          <button class="review-more" type="button">Lire la suite</button>
          <footer class="review-foot">
            <cite>{r.author}</cite>
            <span>{r.date ? `${r.date} · ` : ''}via Google</span>
          </footer>
        </blockquote>
      ))
    }
  </Carousel>

  {
    !connected && (
      <p class="reviews-note">
        Avis affichés à titre d'exemple. Les vrais avis Google s'afficheront dès
        que la clé API et l'ID de fiche seront renseignés (Phase 3).
      </p>
    )
  }

  {aggregateLd && <script type="application/ld+json" set:html={JSON.stringify(aggregateLd)} />}
</div>

<style>
  .reviews-head {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    justify-content: space-between;
    gap: 20px;
    margin-bottom: 26px;
  }
  .reviews-head h2 {
    margin: 0;
  }
  .reviews-score {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .score-num {
    font-family: var(--serif);
    font-size: 2.4rem;
    line-height: 1;
    color: var(--ink);
  }
  .stars {
    letter-spacing: 2px;
    color: var(--line);
  }
  .stars .on {
    color: var(--ochre);
  }
  .score-meta {
    font-size: 0.85rem;
    color: var(--muted);
  }
  .review-card {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin: 0;
    padding: 24px;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    box-shadow: var(--shadow-sm);
  }
  .review-card .stars {
    font-size: 0.95rem;
  }
  .review-text {
    font-family: var(--serif);
    font-size: 1.08rem;
    line-height: 1.5;
    color: var(--ink);
    margin: 0;
    /* Tronqué à 7 lignes -> toutes les cartes ont la même hauteur */
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 7;
    overflow: hidden;
    min-height: calc(1.5em * 7);
  }
  .review-card.expanded .review-text {
    -webkit-line-clamp: unset;
    overflow: visible;
    min-height: 0;
  }
  .review-more {
    align-self: flex-start;
    visibility: hidden;
    background: none;
    border: 0;
    padding: 2px 0;
    color: var(--accent);
    font-family: var(--sans);
    font-weight: 650;
    font-size: 0.85rem;
    cursor: pointer;
  }
  .review-more.is-visible {
    visibility: visible;
  }
  .review-more:hover {
    color: var(--accent-strong);
    text-decoration: underline;
  }
  .review-foot {
    display: flex;
    flex-direction: column;
    gap: 2px;
    font-size: 0.82rem;
    color: var(--muted);
  }
  .review-foot cite {
    font-style: normal;
    font-weight: 700;
    color: var(--ink);
  }
  .reviews-note {
    margin: 16px 0 0;
    font-size: 0.8rem;
    color: var(--muted);
    font-style: italic;
  }
</style>

<script>
  document.querySelectorAll('.review-card').forEach((card) => {
    const text = card.querySelector('.review-text');
    const btn = card.querySelector('.review-more');
    if (!text || !btn) return;
    // Le texte dépasse-t-il la troncature (7 lignes) ?
    if (text.scrollHeight - text.clientHeight < 4) return; // avis court : pas de bouton
    btn.classList.add('is-visible');
    btn.addEventListener('click', () => {
      const expanded = card.classList.toggle('expanded');
      btn.textContent = expanded ? 'Voir moins' : 'Lire la suite';
    });
  });
</script>
