---
import { SITE, NAV, LEGAL_NAV } from '../consts';
import Sprig from './Sprig.astro';
import Email from './Email.astro';
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div class="footer-brand">
      <Sprig size={44} />
      <p class="footer-name">{SITE.name}</p>
      <p class="footer-tagline">{SITE.tagline}</p>
    </div>

    <nav class="footer-col" aria-label="Pages">
      <h2>Explorer</h2>
      <ul>
        <li><a href="/">Accueil</a></li>
        {NAV.map((item) => <li><a href={item.href}>{item.label}</a></li>)}
      </ul>
    </nav>

    <div class="footer-col">
      <h2>Contact</h2>
      <ul>
        {SITE.email && <li><Email /></li>}
        {SITE.phone && <li><a href={`tel:${SITE.phone.replace(/\s/g, '')}`}>{SITE.phone}</a></li>}
        <li>Zone : {SITE.areaServed}</li>
        <li><a href={SITE.instagram} target="_blank" rel="noreferrer me">Instagram</a></li>
      </ul>
    </div>

    <nav class="footer-col" aria-label="Informations légales">
      <h2>Légal</h2>
      <ul>
        {LEGAL_NAV.map((item) => <li><a href={item.href}>{item.label}</a></li>)}
      </ul>
    </nav>
  </div>

  <div class="container footer-bottom">
    <p>© {year} {SITE.name}. Tous droits réservés.</p>
    <p>Fleurs de saison · créations sur mesure</p>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: clamp(48px, 8vw, 96px);
    background: var(--surface-2);
    color: var(--muted);
    border-top: 1px solid var(--line);
    padding-block: clamp(44px, 6vw, 72px) 28px;
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr 1fr;
    gap: clamp(28px, 4vw, 56px);
  }
  .footer-brand :global(.sprig) {
    color: var(--accent);
    margin-bottom: 10px;
  }
  .footer-name {
    font-family: var(--serif);
    font-size: 1.3rem;
    color: var(--ink);
    margin: 0 0 6px;
  }
  .footer-tagline {
    color: var(--muted);
    max-width: 34ch;
    margin: 0;
    font-size: 0.95rem;
  }
  .footer-col h2 {
    font-family: var(--sans);
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 14px;
  }
  .footer-col ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 10px;
    font-size: 0.95rem;
  }
  .footer-col a {
    color: var(--muted);
  }
  .footer-col a:hover {
    color: var(--ink);
  }
  .footer-bottom {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 10px;
    margin-top: clamp(32px, 5vw, 52px);
    padding-top: 20px;
    border-top: 1px solid var(--line);
    font-size: 0.82rem;
    color: var(--muted);
  }
  .footer-bottom p {
    margin: 0;
  }

  @media (max-width: 760px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }
    .footer-brand {
      grid-column: 1 / -1;
    }
  }
  @media (max-width: 460px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
