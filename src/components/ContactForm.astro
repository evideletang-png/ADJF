---
import Email from './Email.astro';
import { SITE } from '../consts';

/*
 * Formulaire de contact — MAQUETTE fonctionnelle (Phase 1).
 * Aujourd'hui : validation, anti-spam (honeypot), et confirmation
 * personnalisée selon le type de projet (aperçu du tri « intelligent »).
 * En Phase 3 : envoi vers une fonction serverless -> API Gmail
 * (classement, libellé, accusé de réception, brouillon de réponse).
 */

// Fourchettes de budget éditables au CMS (src/data/site.json -> budgetOptions).
// On tolère aussi bien des chaînes simples que des objets {label}/{value}.
const budgetOptions: string[] = (((SITE as any).budgetOptions ?? []) as any[])
  .map((o) => (typeof o === 'string' ? o : o?.label ?? o?.value ?? ''))
  .map((s) => String(s).trim())
  .filter(Boolean);
---

<form class="contact-form" id="contact-form" novalidate>
  <div class="field-grid">
    <label class="field">
      <span>Nom<i>*</i></span>
      <input type="text" name="name" autocomplete="name" required />
    </label>
    <label class="field">
      <span>Email<i>*</i></span>
      <input type="email" name="email" autocomplete="email" required />
    </label>
  </div>

  <div class="field-grid">
    <label class="field">
      <span>Téléphone</span>
      <input type="tel" name="phone" autocomplete="tel" />
    </label>
    <label class="field">
      <span>Type de projet</span>
      <select name="projectType">
        <option value="Mariage">Mariage</option>
        <option value="Événement privé">Événement privé</option>
        <option value="Événement professionnel">Événement professionnel</option>
        <option value="Abonnement floral">Abonnement floral</option>
        <option value="Atelier floral">Atelier floral</option>
        <option value="Autre">Autre</option>
      </select>
    </label>
  </div>

  <div class="field-grid">
    <label class="field">
      <span>Date souhaitée</span>
      <input type="date" name="eventDate" />
    </label>
    <div class="field">
      <span id="cf-location-label">Lieu ou ville</span>
      <div class="ac" data-ac>
        <input
          type="text"
          name="location"
          placeholder="Domaine, salle, ville…"
          autocomplete="off"
          autocorrect="off"
          autocapitalize="off"
          spellcheck="false"
          role="combobox"
          aria-labelledby="cf-location-label"
          aria-autocomplete="list"
          aria-expanded="false"
          aria-controls="cf-location-list"
        />
        <ul class="ac-list" id="cf-location-list" role="listbox" aria-label="Suggestions d'adresses" hidden></ul>
      </div>
    </div>
  </div>

  <label class="field">
    <span>Budget indicatif</span>
    <select name="budget">
      <option value="">Je ne sais pas encore</option>
      {budgetOptions.map((o) => <option value={o}>{o}</option>)}
    </select>
  </label>

  <label class="field">
    <span>Votre projet<i>*</i></span>
    <textarea name="message" rows="5" required placeholder="Ambiance, couleurs, nombre d'invités, inspirations…"></textarea>
  </label>

  {/* Anti-spam : champ piège, invisible pour les humains */}
  <div class="hp" aria-hidden="true">
    <label>Ne pas remplir<input type="text" name="entreprise" tabindex="-1" autocomplete="off" /></label>
  </div>

  <label class="consent">
    <input type="checkbox" name="consent" required />
    <span>J'accepte que mes informations soient utilisées pour être recontacté·e au sujet de ma demande.<i>*</i></span>
  </label>

  <div class="form-foot">
    <button class="btn btn-primary" type="submit">Envoyer la demande</button>
    <p class="form-hint">
      Réponse sous 48&nbsp;h. Ou écrivez directement à <Email />.
    </p>
  </div>

  <p class="form-status" id="form-status" role="status" aria-live="polite"></p>
</form>

<div class="form-success card" id="form-success" hidden>
  <svg width="46" height="46" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6L9 17l-5-5" /></svg>
  <h3 id="success-title">Demande envoyée</h3>
  <p id="success-message"></p>
</div>

<style>
  .contact-form {
    display: grid;
    gap: 16px;
  }
  .field-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  .field {
    display: grid;
    gap: 7px;
  }
  .field > span {
    font-size: 0.82rem;
    font-weight: 650;
    color: var(--muted);
  }
  .field i {
    color: var(--rose);
    font-style: normal;
    margin-left: 2px;
  }
  .contact-form input,
  .contact-form select,
  .contact-form textarea {
    width: 100%;
    min-height: 50px;
    padding: 0 14px;
    border: 1px solid var(--line);
    border-radius: var(--radius-sm);
    background: var(--surface);
    color: var(--ink);
    outline: none;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .contact-form textarea {
    min-height: 130px;
    padding: 12px 14px;
    line-height: 1.5;
    resize: vertical;
  }
  .contact-form input:focus,
  .contact-form select:focus,
  .contact-form textarea:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-tint);
  }
  .contact-form input[aria-invalid='true'],
  .contact-form textarea[aria-invalid='true'] {
    border-color: var(--rose);
  }
  /* Recherche d'adresse (Base Adresse Nationale) */
  .ac {
    position: relative;
  }
  .ac-list {
    position: absolute;
    top: calc(100% + 4px);
    left: 0;
    right: 0;
    z-index: 30;
    margin: 0;
    padding: 4px;
    list-style: none;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius-sm);
    box-shadow: var(--shadow);
    max-height: 264px;
    overflow-y: auto;
  }
  .ac-list[hidden] {
    display: none;
  }
  /* Les options sont créées en JS : styles en :global pour les atteindre
     (le CSS scopé d'Astro ne cible que les éléments présents au build). */
  .ac :global(.ac-option) {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    padding: 9px 11px;
    border-radius: 9px;
    cursor: pointer;
  }
  .ac :global(.ac-option:hover),
  .ac :global(.ac-option[aria-selected='true']) {
    background: var(--accent-tint);
  }
  .ac :global(.ac-pin) {
    flex: 0 0 auto;
    width: 16px;
    height: 16px;
    margin-top: 2px;
    color: var(--accent);
  }
  .ac :global(.ac-text) {
    display: flex;
    flex-direction: column;
    gap: 1px;
    min-width: 0;
  }
  .ac :global(.ac-option strong) {
    font-weight: 600;
    font-size: 0.94rem;
    color: var(--ink);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 100%;
  }
  .ac :global(.ac-option small) {
    font-size: 0.78rem;
    color: var(--muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 100%;
  }
  .hp {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }
  .consent {
    display: flex;
    gap: 12px;
    align-items: flex-start;
    font-size: 0.9rem;
    color: var(--muted);
  }
  .consent input {
    margin-top: 3px;
    width: 18px;
    height: 18px;
    flex: 0 0 auto;
    accent-color: var(--accent);
  }
  .form-foot {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 16px;
  }
  .form-hint {
    margin: 0;
    font-size: 0.85rem;
    color: var(--muted);
  }
  .form-status {
    margin: 0;
    min-height: 1.2em;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--rose);
  }
  .form-success {
    display: none;
    flex-direction: column;
    gap: 8px;
    padding: 32px;
    text-align: center;
    align-items: center;
    color: var(--ink);
  }
  .form-success[hidden] {
    display: none;
  }
  .form-success.show {
    display: flex;
  }
  .form-success svg {
    color: var(--accent);
  }
  .form-success h3 {
    margin: 0;
  }
  .form-success p {
    margin: 0;
    color: var(--muted);
    max-width: 46ch;
  }

  @media (max-width: 560px) {
    .field-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const form = document.querySelector<HTMLFormElement>('#contact-form');
  const status = document.querySelector<HTMLElement>('#form-status');
  const success = document.querySelector<HTMLElement>('#form-success');
  const successMsg = document.querySelector<HTMLElement>('#success-message');

  // Confirmation adaptée au type de projet — aperçu du tri « intelligent »
  // que la fonction Gmail réalisera côté serveur en Phase 3.
  const byType: Record<string, string> = {
    Mariage:
      'Nous préparons une proposition florale pour votre mariage et revenons vers vous sous 48 h avec les prochaines étapes.',
    'Événement privé':
      'Votre demande pour un événement privé est bien notée. Léana vous recontacte sous 48 h.',
    'Événement professionnel':
      'Votre demande professionnelle a été transmise. Nous revenons vers vous sous 48 h avec une première proposition.',
    'Abonnement floral':
      'Merci ! Nous étudions votre besoin d’abonnement floral et vous répondons sous 48 h.',
    'Atelier floral':
      'Votre intérêt pour un atelier est enregistré. Nous vous envoyons les prochaines dates sous 48 h.',
    Autre:
      'Votre message a bien été transmis. Léana vous répond sous 48 h.',
  };

  if (form) {
    const theForm = form;
    const submitBtn = theForm.querySelector<HTMLButtonElement>('button[type="submit"]');

    const showSuccess = (type: string, firstName: string) => {
      if (status) status.textContent = '';
      theForm.hidden = true;
      if (success && successMsg) {
        successMsg.textContent = `${firstName ? firstName + ', m' : 'M'}erci. ${byType[type] ?? byType['Autre']}`;
        success.classList.add('show');
        success.removeAttribute('hidden');
        success.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }
    };

    theForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const data = new FormData(theForm);

      // Anti-spam : si le champ piège est rempli, faux succès (rien n'est envoyé).
      if ((data.get('entreprise') as string)?.trim()) {
        showSuccess((data.get('projectType') as string) || 'Autre', '');
        return;
      }

      // Validation minimale
      const required: Array<[string, string]> = [
        ['name', 'votre nom'],
        ['email', 'votre email'],
        ['message', 'un message'],
      ];
      for (const [field, label] of required) {
        const value = (data.get(field) as string)?.trim();
        const el = theForm.querySelector<HTMLElement>(`[name="${field}"]`);
        if (!value) {
          if (status) status.textContent = `Merci d’indiquer ${label}.`;
          el?.setAttribute('aria-invalid', 'true');
          (el as HTMLElement | null)?.focus();
          return;
        }
        el?.removeAttribute('aria-invalid');
      }
      const email = (data.get('email') as string).trim();
      if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        if (status) status.textContent = 'Cet email semble incorrect.';
        theForm.querySelector('[name="email"]')?.setAttribute('aria-invalid', 'true');
        return;
      }
      if (!(theForm.querySelector('[name="consent"]') as HTMLInputElement)?.checked) {
        if (status) status.textContent = 'Merci de cocher la case de consentement.';
        return;
      }

      const type = (data.get('projectType') as string) || 'Autre';
      const firstName = (data.get('name') as string).trim().split(' ')[0];

      // Envoi au serveur (script PHP -> e-mail OVH)
      if (status) status.textContent = 'Envoi en cours…';
      if (submitBtn) submitBtn.disabled = true;
      try {
        const res = await fetch('/api/contact.php', { method: 'POST', body: data });
        const json = await res.json().catch(() => ({ ok: res.ok }));
        if (json && json.ok && json.delivered) {
          showSuccess(type, firstName);
        } else if (json && json.ok) {
          // L'envoi n'est pas encore configuré : on reste honnête (pas de faux « envoyé »).
          if (status)
            status.textContent =
              'Merci ! Le formulaire n’est pas encore tout à fait finalisé — écrivez-nous directement (adresse ci-dessous), on vous répond vite.';
          if (submitBtn) submitBtn.disabled = false;
        } else {
          if (status)
            status.textContent =
              'Une erreur est survenue. Merci de réessayer, ou de nous écrire directement (adresse ci-dessous).';
          if (submitBtn) submitBtn.disabled = false;
        }
      } catch (_) {
        if (status)
          status.textContent =
            'Envoi impossible pour le moment. Réessayez, ou écrivez-nous directement (adresse ci-dessous).';
        if (submitBtn) submitBtn.disabled = false;
      }
    });
  }
</script>

<script>
  // Recherche d'adresse via la Base Adresse Nationale (api-adresse.data.gouv.fr) :
  // service public gratuit, sans clé ni quota, CORS ouvert. Couvre adresses,
  // lieux-dits (domaines/salles) et communes (ville + code postal).
  (() => {
    const root = document.querySelector<HTMLElement>('[data-ac]');
    const input = root?.querySelector<HTMLInputElement>('input');
    const list = root?.querySelector<HTMLUListElement>('.ac-list');
    if (!root || !input || !list) return;

    type Item = { value: string; main: string; sub: string };
    let items: Item[] = [];
    let active = -1;
    let timer: number | undefined;
    let controller: AbortController | null = null;

    const esc = (s: string) =>
      s.replace(/[&<>"']/g, (c) =>
        ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c] as string)
      );

    const close = () => {
      list.hidden = true;
      list.innerHTML = '';
      items = [];
      active = -1;
      input.setAttribute('aria-expanded', 'false');
      input.removeAttribute('aria-activedescendant');
    };

    const pick = (i: number) => {
      const it = items[i];
      if (!it) return;
      input.value = it.value;
      close();
      input.focus();
    };

    const paint = () => {
      Array.from(list.children).forEach((li, i) => {
        li.setAttribute('aria-selected', String(i === active));
        if (i === active) {
          input.setAttribute('aria-activedescendant', `ac-opt-${i}`);
          (li as HTMLElement).scrollIntoView({ block: 'nearest' });
        }
      });
    };

    const PIN =
      '<svg class="ac-pin" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 12-9 12s-9-5-9-12a9 9 0 0 1 18 0Z"/><circle cx="12" cy="10" r="3"/></svg>';

    const render = () => {
      if (!items.length) return close();
      list.innerHTML = items
        .map(
          (it, i) =>
            `<li class="ac-option" role="option" id="ac-opt-${i}" aria-selected="false">` +
            PIN +
            `<span class="ac-text"><strong>${esc(it.main)}</strong>` +
            (it.sub ? `<small>${esc(it.sub)}</small>` : '') +
            `</span></li>`
        )
        .join('');
      list.hidden = false;
      input.setAttribute('aria-expanded', 'true');
      Array.from(list.children).forEach((li, i) => {
        // mousedown (pas click) : sélectionne avant que le blur ne ferme la liste
        li.addEventListener('mousedown', (e) => {
          e.preventDefault();
          pick(i);
        });
      });
    };

    const search = async (q: string) => {
      controller?.abort();
      controller = new AbortController();
      try {
        const res = await fetch(
          `https://api-adresse.data.gouv.fr/search/?q=${encodeURIComponent(q)}&limit=6&autocomplete=1`,
          { signal: controller.signal }
        );
        if (!res.ok) return;
        const data = await res.json();
        items = ((data.features as any[]) || []).map((f) => {
          const p = f.properties || {};
          const isCity = p.type === 'municipality';
          const cityName = p.city ?? p.name ?? p.label;
          // Département seul (2ᵉ élément du contexte « 41, Loir-et-Cher, Centre-Val de Loire »)
          const dept = (p.context || '').split(',')[1]?.trim() || p.context || '';
          return {
            value: isCity && p.postcode ? `${cityName} (${p.postcode})` : p.label,
            main: isCity ? cityName : p.name ?? p.label,
            sub: isCity
              ? [p.postcode, dept].filter(Boolean).join(' · ')
              : [p.postcode, p.city].filter(Boolean).join(' '),
          } as Item;
        });
        active = -1;
        render();
      } catch (_) {
        /* réseau indisponible ou requête annulée : on ignore, l'utilisateur peut saisir librement */
      }
    };

    input.addEventListener('input', () => {
      const q = input.value.trim();
      if (timer) window.clearTimeout(timer);
      if (q.length < 3) return close();
      timer = window.setTimeout(() => search(q), 250);
    });

    input.addEventListener('keydown', (e) => {
      if (list.hidden) return;
      if (e.key === 'ArrowDown') {
        e.preventDefault();
        active = Math.min(active + 1, items.length - 1);
        paint();
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        active = Math.max(active - 1, 0);
        paint();
      } else if (e.key === 'Enter' && active >= 0) {
        e.preventDefault();
        pick(active);
      } else if (e.key === 'Escape') {
        close();
      }
    });

    document.addEventListener('click', (e) => {
      if (!root.contains(e.target as Node)) close();
    });
  })();
</script>
